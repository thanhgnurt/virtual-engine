{
  "name": "virtual-engine",
  "version": "1.0.6",
  "private": true,
  "description": "High-performance, zero-allocation rendering engine monorepo.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w virtual-engine",
    "build:react": "npm run build -w react-virtual-engine",
    "dev:core": "npm run dev -w virtual-engine",
    "dev:react": "npm run dev -w react-virtual-engine",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "publish:all": "npm run build && npm publish -w virtual-engine --access public && npm publish -w react-virtual-engine --access public",
    "release": "npm run version:patch && npm run publish:all",
    "dev": "node -r ./scripts/crypto-polyfill.js ./node_modules/vite/bin/vite.js examples/introduction",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { try { require('husky').install() } catch (e) {} }\""
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "author": "Thanh Trung Le <thanhgnurt@gmail.com>",
  "license": "MIT",
  "homepage": "https://react-virtual-engine.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thanhgnurt/virtual-engine.git"
  },
  "bugs": {
    "url": "https://github.com/thanhgnurt/virtual-engine/issues"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0"
  }
}
