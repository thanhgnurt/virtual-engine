{
  "name": "react-virtual-engine",
  "version": "1.0.7",
  "description": "React components and hooks for the high-performance virtual-engine.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts"
  },
  "keywords": [
    "react",
    "virtualization",
    "performance",
    "windowing"
  ],
  "author": "Thanh Trung Le <thanhgnurt@gmail.com>",
  "license": "MIT",
  "homepage": "https://react-virtual-engine.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thanhgnurt/virtual-engine.git"
  },
  "bugs": {
    "url": "https://github.com/thanhgnurt/virtual-engine/issues"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "virtual-engine": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
