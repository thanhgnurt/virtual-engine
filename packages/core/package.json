  "keywords": [
    "virtualization",
    "performance",
    "rendering-engine",
    "zero-allocation"
  ],
  "author": "Thanh Trung Le <thanhgnurt@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
