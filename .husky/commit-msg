#!/usr/bin/env sh

# Load NVM and use Node 22
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
nvm use 22 > /dev/null 2>&1

# Run commitlint and capture output
OUTPUT=$(npx --no -- commitlint --edit "${1}" 2>&1)
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌❌❌ ---------------------------------------------------------------------- ❌❌❌"
  echo "❌ ERROR: Commit message does not follow Conventional Commits format.         ❌"
  echo "❌ Commit aborted.                                                            ❌"
  echo "❌❌❌ ---------------------------------------------------------------------- ❌❌❌"
  echo ""
  echo "📋 Commitlint output:"
  echo "$OUTPUT"
  echo ""
  echo "💡 Expected format:  <type>(<scope>): <subject>"
  echo "   Examples:"
  echo "     feat(core): add virtual scroll support"
  echo "     fix(react): resolve memory leak in VirtualList"
  echo "     docs: update README with usage examples"
  echo "     chore: upgrade dependencies"
  echo ""
  echo "   Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo ""
  exit $EXIT_CODE
fi
