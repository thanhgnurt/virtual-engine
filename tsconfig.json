{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["DOM", "DOM.Iterable", "ES6"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "virtual-engine": ["packages/core/virtual-engine/src/index.ts"],
      "react-virtual-engine": ["packages/ui/react-virtual-engine/src/index.ts"],
      "virtual-chatbot": ["packages/core/virtual-chatbot/src/index.ts"],
      "react-virtual-chatbot": ["packages/ui/react-virtual-chatbot/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "**/node_modules/*"]
}
